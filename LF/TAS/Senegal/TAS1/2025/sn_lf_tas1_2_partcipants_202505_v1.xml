<?xml version="1.0" encoding="UTF-8"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:odk="http://www.opendatakit.org/xforms">
	<h:head>
		<h:title>(2025 Mai) 2. TAS1 FL - Formulaire Participants V1</h:title>
		<model>
			<itext>
				<translation lang="English">
					<text id="yes_no-0">
						<value>Yes</value>
					</text>
					<text id="yes_no-1">
						<value>No</value>
					</text>
					<text id="sex_list-0">
						<value>Male</value>
					</text>
					<text id="sex_list-1">
						<value>Female</value>
					</text>
					<text id="id_list-0">
						<value>Scanner</value>
					</text>
					<text id="id_list-1">
						<value>Automatic ID generation</value>
					</text>
					<text id="/data/p_recorder:jr:constraintMsg">
						<value>The code must be a two-digit number</value>
					</text>
					<text id="/data/p_recorder:label">
						<value>Enter Recorder ID</value>
					</text>
					<text id="/data/p_recorder:hint">
						<value>If you are the only recorder on your team, this may be called a "team ID". Recorder ID is the 2-digit code assigned to you or your team.</value>
					</text>
					<text id="/data/p_eu_name:label">
						<value>Select your evaluation unit (EU)</value>
					</text>
					<text id="/data/p_commune:label">
						<value>Select your commune</value>
					</text>
					<text id="/data/p_cluster_name:label">
						<value>Select your school name</value>
					</text>
					<text id="/data/p_cluster_id:label">
						<value>Select your school id</value>
					</text>
					<text id="/data/Enfant:label">
						<value>Enfants</value>
					</text>
					<text id="/data/Enfant/p_consent:label">
						<value>Does respondent provide consent?</value>
					</text>
					<text id="/data/Enfant/p_sex:label">
						<value>Sex of respondent</value>
					</text>
					<text id="/data/Enfant/p_age_yrs:jr:constraintMsg">
						<value>The age must be between 5 and 9 years</value>
					</text>
					<text id="/data/Enfant/p_age_yrs:label">
						<value>Enter age in years</value>
					</text>
					<text id="/data/Enfant/p_how_long_lived:jr:constraintMsg">
						<value>The value must not be greater than the age</value>
					</text>
					<text id="/data/Enfant/p_how_long_lived:label">
						<value>How many years has the respondent lived in the area?</value>
					</text>
					<text id="/data/Enfant/p_IDMethod:label">
						<value>How will the individual's unique ID be generated?</value>
					</text>
					<text id="/data/Enfant/p_BarcodeID:label">
						<value>Scan barcode now</value>
					</text>
					<text id="/data/Enfant/p_index:label">
						<value>The order number of this participant is:</value>
					</text>
					<text id="/data/Enfant/p_code_id:label">
						<value>The unique code of this participant is:</value>
					</text>
					<text id="/data/Enfant/p_ending_survey_note:label">
						<value>You just entered a value that will end the survey</value>
					</text>
					<text id="/data/Enfant/p_notes:label">
						<value>Additional Notes</value>
					</text>
					<text id="/data/Enfant/p_code_id:hint">
						<value>-</value>
					</text>
				</translation>
				<translation lang="French" default="true()">
					<text id="yes_no-0">
						<value>Oui</value>
					</text>
					<text id="yes_no-1">
						<value>Non</value>
					</text>
					<text id="sex_list-0">
						<value>Masculin</value>
					</text>
					<text id="sex_list-1">
						<value>Féminin</value>
					</text>
					<text id="id_list-0">
						<value>Scanner</value>
					</text>
					<text id="id_list-1">
						<value>Génération automatique</value>
					</text>
					<text id="/data/p_recorder:jr:constraintMsg">
						<value>Le code doit être un nombre à deux chiffres</value>
					</text>
					<text id="/data/p_recorder:label">
						<value>Entrez l'identifiant de l'enregistreur</value>
					</text>
					<text id="/data/p_recorder:hint">
						<value>Si vous êtes le seul enregistreur de votre équipe, cela peut être appelé un "identifiant d'équipe". L'identifiant de l'enregistreur est un code à 2 chiffres qui a été attribué à vous ou à votre équipe.</value>
					</text>
					<text id="/data/p_eu_name:label">
						<value>Sélectionnez l'unité d'évaluation (UE)</value>
					</text>
					<text id="/data/p_commune:label">
						<value>Sélectionnez la commune</value>
					</text>
					<text id="/data/p_cluster_name:label">
						<value>Sélectionnez l'école</value>
					</text>
					<text id="/data/p_cluster_id:label">
						<value>Sélectionnez le code de l'école</value>
					</text>
					<text id="/data/Enfant:label">
						<value>Enfants</value>
					</text>
					<text id="/data/Enfant/p_consent:label">
						<value>Le répondant (participant) a-t-il donné son assentiment/consentement?</value>
					</text>
					<text id="/data/Enfant/p_sex:label">
						<value>Sexe du participant</value>
					</text>
					<text id="/data/Enfant/p_age_yrs:jr:constraintMsg">
						<value>L'age doit être compris entre 5 et 9 ans</value>
					</text>
					<text id="/data/Enfant/p_age_yrs:label">
						<value>Entrez l'âge du participant (en années)</value>
					</text>
					<text id="/data/Enfant/p_how_long_lived:jr:constraintMsg">
						<value>La valeur ne doit pas être supérieure à l'âge</value>
					</text>
					<text id="/data/Enfant/p_how_long_lived:label">
						<value>Depuis combien d'années le participant habite-t-il dans la communauté?</value>
					</text>
					<text id="/data/Enfant/p_IDMethod:label">
						<value>Comment l'ID unique de l'individu sera-t-il généré?</value>
					</text>
					<text id="/data/Enfant/p_BarcodeID:label">
						<value>Scannez le code-barres maintenant</value>
					</text>
					<text id="/data/Enfant/p_index:label">
						<value>Le numéro d'ordre de ce participant est:</value>
					</text>
					<text id="/data/Enfant/p_code_id:label">
						<value>Le code unique personnel de ce participant est:</value>
					</text>
					<text id="/data/Enfant/p_code_id:hint">
						<value>[Code du site]-[Numéro d'ordre]</value>
					</text>
					<text id="/data/Enfant/p_ending_survey_note:label">
						<value>Vous avez sélectionné une valeur qui mettra fin à l'enquête pour ce participant.</value>
					</text>
					<text id="/data/Enfant/p_notes:label">
						<value>Notes complémentaires</value>
					</text>
				</translation>
			</itext>
			
			<instance>
				<data id="sn_lf_tas1_2_participants_202505_v1">
					<p_recorder/>
					<p_eu_name/>
					<p_commune/>
					<p_cluster_name/>
					<p_cluster_id/>
					<p_index_init/>
					<Enfant jr:template="">
						<p_consent/>
						<p_sex/>
						<p_age_yrs/>
						<p_how_long_lived/>
						<p_IDMethod/>
						<p_BarcodeID/>
						<p_index/>
						<p_code_id/>
						<position/>
						<p_ending_survey_note/>
						<p_notes/>
					</Enfant>
					<Enfant>
						<p_consent/>
						<p_sex/>
						<p_age_yrs/>
						<p_how_long_lived/>
						<p_IDMethod/>
						<p_BarcodeID/>
						<p_index/>
						<p_code_id/>
						<position/>
						<p_ending_survey_note/>
						<p_notes/>
					</Enfant>
					<p_index_cur/>
					<c_start/>
					<c_end/>
					<meta>
						<instanceID/>
					</meta>
				</data>
			</instance>
			<instance id="__last-saved" src="jr://instance/last-saved"/>
			<instance id="yes_no">
				<root>
					<item>
						<itextId>yes_no-0</itextId>
						<name>Yes</name>
					</item>
					<item>
						<itextId>yes_no-1</itextId>
						<name>No</name>
					</item>
				</root>
			</instance>
			<instance id="sex_list">
				<root>
					<item>
						<itextId>sex_list-0</itextId>
						<name>Male</name>
					</item>
					<item>
						<itextId>sex_list-1</itextId>
						<name>Female</name>
					</item>
				</root>
			</instance>
			<instance id="id_list">
				<root>
					<item>
						<itextId>id_list-0</itextId>
						<name>Scanner</name>
					</item>
					<item>
						<itextId>id_list-1</itextId>
						<name>ID_generation</name>
					</item>
				</root>
			</instance>
			<bind nodeset="/data/p_recorder" type="string" constraint="regex(.,'^[0-9]{2}$')" jr:constraintMsg="jr:itext('/data/p_recorder:jr:constraintMsg')" required="true()"/>
			<bind nodeset="/data/p_eu_name" type="string" required="true()" db_get="col_1"/>
			<bind nodeset="/data/p_commune" type="string" required="true()" db_get="col_2" db_filter_by_col_1=" /data/p_eu_name "/>
			<bind nodeset="/data/p_cluster_name" type="string" required="true()" db_get="col_3" db_filter_by_col_2=" /data/p_commune "/>
			<bind nodeset="/data/p_cluster_id" type="string" required="true()" db_get="col_4" db_filter_by_col_3=" /data/p_cluster_name "/>
			<bind nodeset="/data/p_index_init" type="integer" calculate="once(if( instance('__last-saved')/data/p_index_cur !=null, instance('__last-saved')/data/p_index_cur , 0))"/>
			<bind nodeset="/data/Enfant/p_consent" type="string" required="true()"/>
			<bind nodeset="/data/Enfant/p_sex" type="string" relevant=" ../p_consent  = 'Yes'" required="true()"/>
			<bind nodeset="/data/Enfant/p_age_yrs" type="int" constraint=". &gt;= 5 and . &lt;= 9" jr:constraintMsg="jr:itext('/data/Enfant/p_age_yrs:jr:constraintMsg')" relevant=" ../p_consent  = 'Yes'" required="true()"/>
			<bind nodeset="/data/Enfant/p_how_long_lived" type="int" constraint=". &lt;=  ../p_age_yrs " jr:constraintMsg="jr:itext('/data/Enfant/p_how_long_lived:jr:constraintMsg')" relevant=" ../p_consent  = 'Yes'" required="true()"/>
			<bind nodeset="/data/Enfant/p_IDMethod" type="string" relevant=" ../p_consent  = 'Yes'" required="true()"/>
			<bind nodeset="/data/Enfant/p_BarcodeID" type="barcode" relevant=" ../p_IDMethod  = 'Scanner' and  ../p_consent  = 'Yes'" required="true()"/>
			<bind nodeset="/data/Enfant/p_index" type="int" relevant=" ../p_IDMethod  = 'ID_generation' and  ../p_consent  = 'Yes'" calculate=" /data/p_index_init  + position(..)" required="true()" readonly="true()"/>
			<bind nodeset="/data/Enfant/p_code_id" type="string" relevant=" ../p_consent  = 'Yes'" calculate="if( ../p_IDMethod  = 'Scanner',  ../p_BarcodeID , concat( /data/p_cluster_id , '-',  /data/p_index_init  + position(..)))" readonly="true()" db_add_col_4=" /data/p_cluster_id " db_add_col_5="."/>
			<bind nodeset="/data/Enfant/position" type="string" calculate="position(..)"/>
			<bind nodeset="/data/Enfant/p_ending_survey_note" readonly="true()" type="string" relevant=" ../p_consent  = 'No'"/>
			<bind nodeset="/data/Enfant/p_notes" type="string"/>
			<bind nodeset="/data/p_index_cur" type="string" calculate=" /data/p_index_init  + indexed-repeat( /data/Enfant/position ,  /data/Enfant , count( /data/Enfant ))"/>
			<bind nodeset="/data/c_start" jr:preload="timestamp" type="dateTime" jr:preloadParams="start"/>
			<bind nodeset="/data/c_end" jr:preload="timestamp" type="dateTime" jr:preloadParams="end"/>
			<bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/>
		</model>
	</h:head>
	<h:body>
		<input ref="/data/p_recorder">
			<label ref="jr:itext('/data/p_recorder:label')"/>
			<hint ref="jr:itext('/data/p_recorder:hint')"/>
		</input>
		<input ref="/data/p_eu_name">
			<label ref="jr:itext('/data/p_eu_name:label')"/>
		</input>
		<input ref="/data/p_commune">
			<label ref="jr:itext('/data/p_commune:label')"/>
		</input>
		<input ref="/data/p_cluster_name">
			<label ref="jr:itext('/data/p_cluster_name:label')"/>
		</input>
		<input ref="/data/p_cluster_id">
			<label ref="jr:itext('/data/p_cluster_id:label')"/>
		</input>
		<group ref="/data/Enfant">
			<label ref="jr:itext('/data/Enfant:label')"/>
			<repeat nodeset="/data/Enfant">
				<select1 ref="/data/Enfant/p_consent">
					<label ref="jr:itext('/data/Enfant/p_consent:label')"/>
					<itemset nodeset="instance('yes_no')/root/item">
						<value ref="name"/>
						<label ref="jr:itext(itextId)"/>
					</itemset>
				</select1>
				<select1 ref="/data/Enfant/p_sex">
					<label ref="jr:itext('/data/Enfant/p_sex:label')"/>
					<itemset nodeset="instance('sex_list')/root/item">
						<value ref="name"/>
						<label ref="jr:itext(itextId)"/>
					</itemset>
				</select1>
				<input ref="/data/Enfant/p_age_yrs">
					<label ref="jr:itext('/data/Enfant/p_age_yrs:label')"/>
				</input>
				<input ref="/data/Enfant/p_how_long_lived">
					<label ref="jr:itext('/data/Enfant/p_how_long_lived:label')"/>
				</input>
				<select1 ref="/data/Enfant/p_IDMethod">
					<label ref="jr:itext('/data/Enfant/p_IDMethod:label')"/>
					<itemset nodeset="instance('id_list')/root/item">
						<value ref="name"/>
						<label ref="jr:itext(itextId)"/>
					</itemset>
				</select1>
				<input ref="/data/Enfant/p_BarcodeID">
					<label ref="jr:itext('/data/Enfant/p_BarcodeID:label')"/>
				</input>
				<input ref="/data/Enfant/p_index">
					<label ref="jr:itext('/data/Enfant/p_index:label')"/>
				</input>
				<input ref="/data/Enfant/p_code_id">
					<label ref="jr:itext('/data/Enfant/p_code_id:label')"/>
					<hint ref="jr:itext('/data/Enfant/p_code_id:hint')"/>
				</input>
				<input ref="/data/Enfant/p_ending_survey_note">
					<label ref="jr:itext('/data/Enfant/p_ending_survey_note:label')"/>
				</input>
				<input ref="/data/Enfant/p_notes">
					<label ref="jr:itext('/data/Enfant/p_notes:label')"/>
				</input>
			</repeat>
		</group>
	</h:body>
</h:html>