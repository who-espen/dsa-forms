			<bind db_filter_by_col_2=" /lr_lf_pretas_4_quality_controle_202506/q_district_eu " db_get="col_3" nodeset="/lr_lf_pretas_4_quality_controle_202506/q_cluster_name" required="true()" type="string"/>
