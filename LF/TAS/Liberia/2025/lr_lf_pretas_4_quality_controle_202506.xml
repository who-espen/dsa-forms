			<bind constraint="regex(.,'^[0-9]{2}$')" jr:constraintMsg="jr:itext('/lr_lf_pretas_4_quality_controle_202506/q_recorder:jr:constraintMsg')" nodeset="/lr_lf_pretas_4_quality_controle_202506/q_recorder" required="true()" type="string"/>
			<bind db_get="col_1" nodeset="/lr_lf_pretas_4_quality_controle_202506/q_county_iu" required="true()" type="string"/>
