			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q_id_type" required="true()" type="select1"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q_warning_note" required="true()" type="select1"/>
			<bind calculate="join(' ',  /lr_lf_pretas_4_quality_controle_202506/q2506/q_code_id )" nodeset="/lr_lf_pretas_4_quality_controle_202506/C1" type="text"/>
			<bind calculate="position(..)" nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/C2" type="text"/>
			<bind calculate="if ( ../C2  = 1,'',substring-after( /lr_lf_pretas_4_quality_controle_202506/C1 , ../q_code_id ))" nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/C3" type="text"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_add_record" type="select1"/>
			<bind db_filter_by_col_4=" /lr_lf_pretas_4_quality_controle_202506/q_cluster_id " db_get="col_5" nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_code_id1" relevant=" ../q_add_record  = 'Yes' and  /lr_lf_pretas_4_quality_controle_202506/q_id_type  = 'ID_generation'" type="string"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_barcode_method" relevant=" ../q_add_record  = 'Yes' and  /lr_lf_pretas_4_quality_controle_202506/q_id_type  = 'Scanner'" required="true()" type="select1"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_code_id3" relevant=" ../q_add_record  = 'Yes' and  ../q_barcode_method  = 'QRScann'" required="true()" type="barcode"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_code_id4" relevant=" ../q_add_record  = 'Yes' and  ../q_barcode_method  = 'QRManual'" required="true()" type="string"/>
			<bind constraint=". =  ../q_code_id4 " jr:constraintMsg="jr:itext('/lr_lf_pretas_4_quality_controle_202506/q2506/q_code_id5:jr:constraintMsg')" nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_code_id5" relevant=" ../q_add_record  = 'Yes' and  ../q_barcode_method  = 'QRManual'" required="true()" type="string"/>
			<bind calculate="if( /lr_lf_pretas_4_quality_controle_202506/q_id_type  = 'ID_generation',  ../q_code_id1 , if( ../q_barcode_method  = 'QRScann',  ../q_code_id3 ,  ../q_code_id5 ))" constraint="not(selected( ../C3 ,  ../q_code_id ))" jr:constraintMsg="jr:itext('/lr_lf_pretas_4_quality_controle_202506/q2506/q_code_id:jr:constraintMsg')" nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_code_id" readonly="true()" relevant=" ../q_add_record  = 'Yes'" required="true()" type="string"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_mf_date" relevant=" ../q_add_record  = 'Yes'" required="true()" type="date"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_mf_time" relevant=" ../q_add_record  = 'Yes'" required="true()" type="select1"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_blooq_vol_microL" relevant=" ../q_add_record  = 'Yes'" required="true()" type="int"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_mf_result" relevant=" ../q_add_record  = 'Yes'" required="true()" type="select1"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_mf_per_60microL" relevant=" ../q_mf_result  = 'Positive'" required="true()" type="int"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_mf_species" relevant=" ../q_mf_result  = 'Positive'" required="true()" type="select"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_mf_species_other" relevant="selected( ../q_mf_species , 'Other')" required="true()" type="string"/>
			<bind nodeset="/lr_lf_pretas_4_quality_controle_202506/q2506/q_comments" relevant=" ../q_add_record  = 'Yes'" type="string"/>
			<bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/lr_lf_pretas_4_quality_controle_202506/q_start" type="dateTime"/>
			<bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/lr_lf_pretas_4_quality_controle_202506/q_end" type="dateTime"/>
			<bind jr:preload="uid" nodeset="/lr_lf_pretas_4_quality_controle_202506/meta/instanceID" readonly="true()" type="string"/>
		</model>
