			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_barcode_method" relevant=" ../p_consent  = 'Yes' and  /lr_lf_pretas_2_participant_202507/p_id_type  = 'Scanner'" required="true()" type="select1"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_code_id3" relevant=" ../p_consent  = 'Yes' and  ../p_barcode_method  = 'QRScann'" required="true()" type="barcode"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_code_id4" relevant=" ../p_consent  = 'Yes' and  ../p_barcode_method  = 'QRManual'" required="true()" type="string"/>
			<bind constraint=". =  ../p_code_id4 " jr:constraintMsg="jr:itext('/lr_lf_pretas_2_participant_202507/p2507/p_code_id5:jr:constraintMsg')" nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_code_id5" relevant=" ../p_consent  = 'Yes' and  ../p_barcode_method  = 'QRManual'" required="true()" type="string"/>
			<bind calculate="if( /lr_lf_pretas_2_participant_202507/p_id_type  = 'Auto-generated codes',  ../p_code_id1 , if( /lr_lf_pretas_2_participant_202507/p_id_type  = 'Manual numbering',  ../p_code_id2 , if( ../p_barcode_method  = 'QRScann',  ../p_code_id3 ,  ../p_code_id5 )))" constraint="not(selected( ../C3 ,  ../p_code_id ))" db_add_col_4=" /lr_lf_pretas_2_participant_202507/p_cluster_id " db_add_col_5="." jr:constraintMsg="jr:itext('/lr_lf_pretas_2_participant_202507/p2507/p_code_id:jr:constraintMsg')" nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_code_id" readonly="true()" relevant=" ../p_consent  = 'Yes'" required="true()" type="string"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_sex" relevant=" ../p_consent  = 'Yes'" required="true()" type="select1"/>
			<bind constraint=". &gt;= 20" jr:constraintMsg="jr:itext('/lr_lf_pretas_2_participant_202507/p2507/p_age_yrs:jr:constraintMsg')" nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_age_yrs" relevant=" ../p_consent  = 'Yes'" required="true()" type="int"/>
			<bind constraint=". &lt;=  ../p_age_yrs " jr:constraintMsg="jr:itext('/lr_lf_pretas_2_participant_202507/p2507/p_how_long_lived:jr:constraintMsg')" nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_how_long_lived" relevant=" ../p_consent  = 'Yes'" required="true()" type="int"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_swallow_med" relevant=" ../p_consent  = 'Yes'" required="true()" type="select1"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_time_taken_med" relevant=" ../p_consent  = 'Yes' and  ../p_swallow_med  = 'Yes'" required="true()" type="int"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_mosquito_net" relevant=" ../p_consent  = 'Yes'" required="true()" type="select1"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_sleep_mosq_net" relevant=" ../p_consent  = 'Yes' and  ../p_mosquito_net  = 'Yes'" type="select1"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_ending_survey_note" readonly="true()" relevant=" ../p_consent  = 'No'" type="string"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_comments" type="string"/>
			<bind calculate=" /lr_lf_pretas_2_participant_202507/p_index_init  + indexed-repeat( /lr_lf_pretas_2_participant_202507/p2507/position ,  /lr_lf_pretas_2_participant_202507/p2507 , count( /lr_lf_pretas_2_participant_202507/p2507 ))" nodeset="/lr_lf_pretas_2_participant_202507/p_index_cur" relevant=" /lr_lf_pretas_2_participant_202507/p_id_type  = 'Auto-generated codes'" type="string"/>
			<bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/lr_lf_pretas_2_participant_202507/p_start" type="dateTime"/>
			<bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/lr_lf_pretas_2_participant_202507/p_end" type="dateTime"/>
			<bind jr:preload="uid" nodeset="/lr_lf_pretas_2_participant_202507/meta/instanceID" readonly="true()" type="string"/>
		</model>
