			<bind calculate="concat( /lr_lf_pretas_2_participant_202507/p_cluster_id , '-',  /lr_lf_pretas_2_participant_202507/p_index_init  + position(..))" nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_code_id1" relevant=" ../p_consent  = 'Yes' and  /lr_lf_pretas_2_participant_202507/p_id_type  = 'Auto-generated codes'" type="string"/>
			<bind calculate="position(..)" nodeset="/lr_lf_pretas_2_participant_202507/p2507/position" relevant=" ../p_consent  = 'Yes' and  /lr_lf_pretas_2_participant_202507/p_id_type  = 'Auto-generated codes'" type="string"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_num_order" relevant=" ../p_consent  = 'Yes' and  /lr_lf_pretas_2_participant_202507/p_id_type  = 'Manual numbering'" required="true()" type="int"/>
