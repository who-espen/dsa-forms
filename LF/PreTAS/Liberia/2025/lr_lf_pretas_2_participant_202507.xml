			<bind calculate="once(if( instance('__last-saved')/lr_lf_pretas_2_participant_202507/p_index_cur !=null, instance('__last-saved')/lr_lf_pretas_2_participant_202507/p_index_cur , 0))" nodeset="/lr_lf_pretas_2_participant_202507/p_index_init" type="integer"/>
			<bind calculate="join(' ',  /lr_lf_pretas_2_participant_202507/p2507/p_code_id )" nodeset="/lr_lf_pretas_2_participant_202507/C1" type="text"/>
			<bind calculate="position(..)" nodeset="/lr_lf_pretas_2_participant_202507/p2507/C2" type="text"/>
			<bind calculate="if ( ../C2  = 1,'',substring-after( /lr_lf_pretas_2_participant_202507/C1 , ../p_code_id ))" nodeset="/lr_lf_pretas_2_participant_202507/p2507/C3" type="text"/>
			<bind nodeset="/lr_lf_pretas_2_participant_202507/p2507/p_consent" type="select1"/>
