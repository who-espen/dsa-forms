      <bind calculate="concat( /data/p_site_code , '-',  /data/p_index_init  + position(..))" nodeset="/data/p_sppa2510_3/p_code_id1" type="string"/>
      <bind calculate="position(..)" nodeset="/data/p_sppa2510_3/position" type="string"/>
      <bind calculate="concat( ../p_code_id1 )" constraint="not(selected( ../C3 ,  ../p_code_id ))" db_add_col_6=" /data/p_site_code " db_add_col_7="." jr:constraintMsg="jr:itext('/data/p_sppa2510_3/p_code_id:jr:constraintMsg')" nodeset="/data/p_sppa2510_3/p_code_id" readonly="true()" relevant=" ../p_consent  = 'A.donne'" required="true()" type="string"/>
