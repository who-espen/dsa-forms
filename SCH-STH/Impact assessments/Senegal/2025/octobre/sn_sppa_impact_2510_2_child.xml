      <bind nodeset="/data/p_sppa2510_3/p_ending_survey_note" readonly="true()" relevant=" ../p_consent  = 'A.refuse'" type="string"/>
      <bind nodeset="/data/p_sppa2510_3/p_remarks" type="string"/>
      <bind nodeset="/data/p_sppa2510_3/p_note_thanks" readonly="true()" relevant=" ../p_consent  = 'A.donne'" type="string"/>
      <bind calculate=" /data/p_index_init  + indexed-repeat( /data/p_sppa2510_3/position ,  /data/p_sppa2510_3 , count( /data/p_sppa2510_3 ))" nodeset="/data/p_index_cur" type="string"/>
