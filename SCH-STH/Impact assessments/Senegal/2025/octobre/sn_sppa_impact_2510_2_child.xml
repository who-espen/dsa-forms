      <bind nodeset="/data/p_sppa2510_3/p_sex" relevant=" ../p_consent  = 'A.donne'" required="true()" type="select1"/>
      <bind nodeset="/data/p_sppa2510_3/p_residence" relevant=" ../p_consent  = 'A.donne'" required="true()" type="select1"/>
      <bind constraint=". &lt;=  ../p_age_yrs " jr:constraintMsg="jr:itext('/data/p_sppa2510_3/p_annes_vecu_village:jr:constraintMsg')" nodeset="/data/p_sppa2510_3/p_annes_vecu_village" relevant=" ../p_consent  = 'A.donne'" required="true()" type="int"/>
      <bind constraint="not(selected(., 'Ne.fréquente.pas') and count-selected(.) &gt; 1)" jr:constraintMsg="jr:itext('/data/p_sppa2510_3/p_mares_deau:jr:constraintMsg')" nodeset="/data/p_sppa2510_3/p_mares_deau" relevant=" ../p_consent  = 'A.donne'" required="true()" type="select"/>
      <bind nodeset="/data/p_sppa2510_3/p_connait_bilh" relevant=" ../p_consent  = 'A.donne'" required="true()" type="select1"/>
