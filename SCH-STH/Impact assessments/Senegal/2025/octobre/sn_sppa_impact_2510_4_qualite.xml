      <bind constraint="regex(.,'^[0-9]{2}$')" jr:constraintMsg="jr:itext('/data/r_recorder:jr:constraintMsg')" nodeset="/data/r_recorder" required="true()" type="string"/>
      <bind db_get="col_1" nodeset="/data/q_region" required="true()" type="string"/>
      <bind db_filter_by_col_1=" /data/q_region " db_get="col_2" nodeset="/data/q_district" required="true()" type="string"/>
      <bind db_filter_by_col_2=" /data/q_district " db_get="col_3" nodeset="/data/q_subdistrict" required="true()" type="string"/>
      <bind db_filter_by_col_3=" /data/q_subdistrict " db_get="col_4" nodeset="/data/q_site_name" required="true()" type="string"/>
      <bind db_filter_by_col_4=" /data/q_site_name " db_get="col_5" nodeset="/data/q_site_code" required="true()" type="string"/>
      <bind calculate="join(' ',  /data/q_sppa2510/q_code_id )" nodeset="/data/C1" type="text"/>
      <bind calculate="position(..)" nodeset="/data/q_sppa2510/C2" type="text"/>
      <bind calculate="if ( ../C2  = 1,'',substring-after( /data/C1 , ../q_code_id ))" nodeset="/data/q_sppa2510/C3" type="text"/>
      <bind nodeset="/data/q_sppa2510/q_barcode_method" required="true()" type="select1"/>
      <bind constraint="not(selected( ../C3 ,  ../q_code_id ))" db_filter_by_col_5=" /data/q_site_code " db_get="col_6" jr:constraintMsg="jr:itext('/data/q_sppa2510/q_code_id:jr:constraintMsg')" nodeset="/data/q_sppa2510/q_code_id" readonly="true()" required="true()" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_test" required="true()" type="select1"/>
      <bind nodeset="/data/q_sppa2510/q_note3" readonly="true()" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_urine_vol" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_sh_egp" required="true()" type="int"/>
      <bind calculate="( ../q_sh_egp *10) div  ../q_urine_vol " nodeset="/data/q_sppa2510/q_sh_egr_10ml" readonly="true()" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_note2" readonly="true()" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_k_positif" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="select1"/>
      <bind nodeset="/data/q_sppa2510/q_sch_man_sa" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_sch_man_sb" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind calculate="( ../q_sch_man_sa  +  ../q_sch_man_sb )*12" nodeset="/data/q_sppa2510/q_sch_man_intensity" readonly="true()" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind calculate="if( ../q_sch_man_intensity &gt;= 400, 1, 0)" nodeset="/data/q_sppa2510/q_sch_man_heavy_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind calculate="if( ../q_sch_man_intensity &gt;= 100 and  ../q_sch_man_intensity  &lt; 400, 1, 0)" nodeset="/data/q_sppa2510/q_sch_man_moderate_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_ascaris_lumb_sa" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_ascaris_lumb_sb" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind calculate="( ../q_ascaris_lumb_sa  +  ../q_ascaris_lumb_sb )*12" nodeset="/data/q_sppa2510/q_ascaris_lumb_intensity" readonly="true()" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind calculate="if( ../q_ascaris_lumb_intensity &gt;= 50000, 1, 0)" nodeset="/data/q_sppa2510/q_ascaris_lumb_heavy_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind calculate="if( ../q_ascaris_lumb_intensity &gt;= 5000 and  ../q_ascaris_lumb_intensity  &lt; 50000, 1, 0)" nodeset="/data/q_sppa2510/q_ascaris_lumb_moderate_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_hookworm_sa" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_hookworm_sb" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind calculate="( ../q_hookworm_sa  +  ../q_hookworm_sb )*12" nodeset="/data/q_sppa2510/q_hookworm_intensity" readonly="true()" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind calculate="if( ../q_hookworm_intensity &gt;= 400, 1, 0)" nodeset="/data/q_sppa2510/q_hookworm_heavy_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind calculate="if( ../q_hookworm_intensity &gt;= 100 and  ../q_hookworm_intensity  &lt; 400, 1, 0)" nodeset="/data/q_sppa2510/q_hookworm_moderate_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_trichuris_sa" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_trichuris_sb" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind calculate="( ../q_trichuris_sa  +  ../q_trichuris_sb )*12" nodeset="/data/q_sppa2510/q_trichuris_intensity" readonly="true()" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
      <bind calculate="if( ../q_trichuris_intensity &gt;= 400, 1, 0)" nodeset="/data/q_sppa2510/q_trichuris_heavy_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind calculate="if( ../q_trichuris_intensity &gt;= 100 and  ../q_trichuris_intensity  &lt; 400, 1, 0)" nodeset="/data/q_sppa2510/q_trichuris_moderate_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_autre_vers" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="select1"/>
      <bind nodeset="/data/q_sppa2510/q_autre_nom_1" relevant=" ../q_k_positif  = 'Oui' and  ../q_autre_vers != 0" required="true()" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_autre_quantite_1a" relevant=" ../q_k_positif  = 'Oui' and  ../q_autre_vers != 0" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_autre_quantite_1b" relevant=" ../q_k_positif  = 'Oui' and  ../q_autre_vers != 0" required="true()" type="int"/>
      <bind calculate="( ../q_autre_quantite_1a  +  ../q_autre_quantite_1b )*12" nodeset="/data/q_sppa2510/q_autre_nom_1_intensity" readonly="true()" relevant=" ../q_k_positif  = 'Oui' and  ../q_autre_vers != 0" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_autre_nom_2" relevant=" ../q_k_positif  = 'Oui' and  ../q_autre_vers  = 2" required="true()" type="string"/>
      <bind nodeset="/data/q_sppa2510/q_autre_quantite_2a" relevant=" ../q_k_positif  = 'Oui' and  ../q_autre_vers  = 2" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_autre_quantite_2b" relevant=" ../q_k_positif  = 'Oui' and  ../q_autre_vers  = 2" required="true()" type="int"/>
      <bind calculate="( ../q_autre_quantite_2a  +  ../q_autre_quantite_2b )*12" nodeset="/data/q_sppa2510/q_autre_nom_2_intensity" readonly="true()" relevant=" ../q_k_positif  = 'Oui' and  ../q_autre_vers  = 2" required="true()" type="int"/>
      <bind nodeset="/data/q_sppa2510/q_remarks" type="string"/>
      <bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/data/q_start" type="dateTime"/>
      <bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/data/q_end" type="dateTime"/>
      <bind jr:preload="uid" nodeset="/data/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
