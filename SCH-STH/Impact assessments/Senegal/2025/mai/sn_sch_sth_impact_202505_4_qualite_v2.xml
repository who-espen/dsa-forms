			<bind calculate="( ../q_ascaris_lumb_sa  +  ../q_ascaris_lumb_sb )*12" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_ascaris_lumb_intensity" readonly="true()" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
			<bind calculate="if( ../q_ascaris_lumb_intensity  &gt;= 50000, 1, 0)" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_ascaris_lumb_heavy_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
