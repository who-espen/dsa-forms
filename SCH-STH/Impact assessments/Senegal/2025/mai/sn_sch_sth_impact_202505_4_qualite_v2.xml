			<bind calculate="join(' ',  /sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_code_id )" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/C1" type="text"/>
			<bind calculate="position(..)" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/C2" type="text"/>
			<bind calculate="if ( ../C2  = 1,'',substring-after( /sn_sch_sth_impact_202505_4_qualite_v2/C1 , ../q_code_id ))" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/C3" type="text"/>
			<bind constraint="not(selected( ../C3 ,  ../q_code_id ))" db_filter_by_col_5=" /sn_sch_sth_impact_202505_4_qualite_v2/q_site_code " db_get="col_6" jr:constraintMsg="jr:itext('/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_code_id:jr:constraintMsg')" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_code_id" required="true()" type="string"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_test" required="true()" type="select1"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_note3" readonly="true()" type="string"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_urine_vol" required="true()" type="int"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_sh_egp" required="true()" type="int"/>
			<bind calculate="( ../q_sh_egp *10) div  ../q_urine_vol " nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_sh_egr_10ml" readonly="true()" required="true()" type="int"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_note2" readonly="true()" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_k_positif" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="select1"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_sch_man_sa" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_sch_man_sb" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
			<bind calculate="( ../q_sch_man_sa  +  ../q_sch_man_sb )*12" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_sch_man_intensity" readonly="true()" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
			<bind calculate="if( ../q_sch_man_intensity  &gt;= 400, 1, 0)" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_sch_man_heavy_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
			<bind calculate="if( ../q_sch_man_intensity  &gt;= 100 and  ../q_sch_man_intensity  &lt; 400, 1, 0)" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_sch_man_moderate_intensity" relevant=" ../q_test  = 'Filtration d urine + Kato katz'" type="string"/>
			<bind nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_schsth2505v2/q_ascaris_lumb_sa" relevant=" ../q_test  = 'Filtration d urine + Kato katz' and  ../q_k_positif  = 'Oui'" required="true()" type="int"/>
