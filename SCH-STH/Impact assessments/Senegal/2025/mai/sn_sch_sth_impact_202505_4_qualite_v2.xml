			<bind constraint="regex(.,'^[0-9]{2}$')" jr:constraintMsg="jr:itext('/sn_sch_sth_impact_202505_4_qualite_v2/r_recorder:jr:constraintMsg')" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/r_recorder" required="true()" type="string"/>
			<bind db_get="col_1" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_region" required="true()" type="string"/>
			<bind constraint=". = 'FATICK' or . = 'KHOMBOLE'" db_filter_by_col_1=" /sn_sch_sth_impact_202505_4_qualite_v2/q_region " db_get="col_2" jr:constraintMsg="jr:itext('/sn_sch_sth_impact_202505_4_qualite_v2/q_district:jr:constraintMsg')" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_district" required="true()" type="string"/>
			<bind db_filter_by_col_2=" /sn_sch_sth_impact_202505_4_qualite_v2/q_district " db_get="col_3" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_subdistrict" required="true()" type="string"/>
			<bind db_filter_by_col_3=" /sn_sch_sth_impact_202505_4_qualite_v2/q_subdistrict " db_get="col_4" nodeset="/sn_sch_sth_impact_202505_4_qualite_v2/q_site_name" required="true()" type="string"/>
