<?xml version="1.0" encoding="UTF-8"?>
<h:html xmlns="http://www.w3.org/2002/xforms"
  xmlns:ev="http://www.w3.org/2001/xml-events"
  xmlns:h="http://www.w3.org/1999/xhtml"
  xmlns:jr="http://openrosa.org/javarosa"
  xmlns:odk="http://www.opendatakit.org/xforms"
  xmlns:orx="http://openrosa.org/xforms"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <h:head>
    <h:title>(2025 Jan) - 3. SCH/STH - Kato Katz</h:title>
    <model>

      <instance>
        <data id="ml_sch_sth_impact_2501_3_kato_katz">
          <k_Recorder/>
          <k_district/>
          <k_subdistrict/>
          <k_site/>
          <k_site_id/>
          <C1/>
          <ml_ia_k_2501 jr:template="">
            <C2/>
            <C3/>
            <k_sequential_code/>
            <k_sequential_code2/>
            <k_code_id/>
            <k_sch_man_sa/>
            <k_ascaris_lumb_sa/>
            <k_hookworm_sa/>
            <k_trichuris_sa/>
            <k_sch_hae_sa/>
            <k_other_parasite/>
            <k_eggs_other_parasite/>
            <k_remarks/>
          </ml_ia_k_2501>
          <k_start/>
          <k_end/>
          <meta>
            <instanceID/>
          </meta>
        </data>
      </instance>

      <itext>
        <translation default="true()" lang="French">
          <text id="/data/ml_ia_k_2501/k_hookworm_sa:label">
            <value>Ankylostome</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_other_parasite:label">
            <value>Nom des autres parasite</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_code_id:label">
            <value>Veuillez enregistrer ce code unique de l'enfant dans les registres et les échantillons de labo</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_sch_hae_sa:label">
            <value>Schistosoma haematobium</value>
          </text>
          <text id="/data/ml_ia_k_2501:label">
            <value>Enrôlement</value>
          </text>
          <text id="/data/k_site_id:label">
            <value>Sélectionner le code du village</value>
          </text>
          <text id="/data/k_subdistrict:label">
            <value>Sélectionner le sous-district</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_code_id:jr:constraintMsg">
            <value>Cet identifiant a déjà été utilisé dans ce village.</value>
          </text>
          <text id="/data/k_Recorder:label">
            <value>Code de l'Opérateur</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_sequential_code:label">
            <value>Veuillez entrer le code séquentiel</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_trichuris_sa:label">
            <value>Trichocéphale trichura</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_sequential_code2:label">
            <value>Répétez le code séquentiel</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_sch_man_sa:label">
            <value>Schistosoma mansoni (oeufs)</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_ascaris_lumb_sa:label">
            <value>Ascaris lumbricoides (œufs)</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_remarks:label">
            <value>Notes additionnelles</value>
          </text>
          <text id="/data/k_district:label">
            <value>Sélectionner le district</value>
          </text>
          <text id="/data/k_site:label">
            <value>Sélectionner le nom du village</value>
          </text>
          <text id="/data/ml_ia_k_2501/k_eggs_other_parasite:label">
            <value>Autres parasites (œufs)</value>
          </text>
        </translation>
      </itext>

      <bind nodeset="/data/k_Recorder" required="true()" type="int"/>
      <bind db_get="col_1" nodeset="/data/k_district" required="true()" type="string"/>
      <bind db_filter_by_col_1="/data/k_district" db_get="col_2" nodeset="/data/k_subdistrict" required="true()" type="string"/>
      <bind db_filter_by_col_2="/data/k_subdistrict" db_get="col_3" nodeset="/data/k_site" required="true()" type="string"/>
      <bind db_filter_by_col_3="/data/k_site" db_get="col_4" nodeset="/data/k_site_id" required="true()" type="string"/>
      <bind calculate="join(' ',  /data/ml_ia_k_2501/k_code_id )" nodeset="/data/C1" type="text"/>
      <bind calculate="position(..)" nodeset="/data/ml_ia_k_2501/C2" type="text"/>
      <bind calculate="if ( ../C2  = 1, '', substring-after( /data/C1 , ../k_code_id ))" nodeset="/data/ml_ia_k_2501/C3" type="text"/>
      <bind nodeset="/data/ml_ia_k_2501/k_sequential_code" required="true()" type="int"/>
      <bind nodeset="/data/ml_ia_k_2501/k_sequential_code2" required="true()" type="int"/>
      <bind calculate="concat( /data/k_Recorder , '_',  /data/k_site_id , '_',  ../k_sequential_code )" constraint="not(selected( ../C3 ,  ../k_code_id ))" jr:constraintMsg="jr:itext('/data/ml_ia_k_2501/k_code_id:jr:constraintMsg')" nodeset="/data/ml_ia_k_2501/k_code_id" readonly="true()" required="true()" type="string"/>
      <bind nodeset="/data/ml_ia_k_2501/k_sch_man_sa" required="true()" type="int"/>
      <bind nodeset="/data/ml_ia_k_2501/k_ascaris_lumb_sa" required="true()" type="int"/>
      <bind nodeset="/data/ml_ia_k_2501/k_hookworm_sa" required="true()" type="int"/>
      <bind nodeset="/data/ml_ia_k_2501/k_trichuris_sa" required="true()" type="int"/>
      <bind nodeset="/data/ml_ia_k_2501/k_sch_hae_sa" type="int"/>
      <bind nodeset="/data/ml_ia_k_2501/k_other_parasite" type="string"/>
      <bind nodeset="/data/ml_ia_k_2501/k_eggs_other_parasite" type="int"/>
      <bind nodeset="/data/ml_ia_k_2501/k_remarks" type="text"/>
      <bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/data/k_start" type="dateTime"/>
      <bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/data/k_end" type="dateTime"/>
      <bind jr:preload="uid" nodeset="/data/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body>
    <input ref="/data/k_Recorder">
      <label ref="jr:itext('/data/k_Recorder:label')"/>
    </input>
    <input ref="/data/k_district">
      <label ref="jr:itext('/data/k_district:label')"/>
    </input>
    <input ref="/data/k_subdistrict">
      <label ref="jr:itext('/data/k_subdistrict:label')"/>
    </input>
    <input ref="/data/k_site">
      <label ref="jr:itext('/data/k_site:label')"/>
    </input>
    <input ref="/data/k_site_id">
      <label ref="jr:itext('/data/k_site_id:label')"/>
    </input>
    <group ref="/data/ml_ia_k_2501">
      <label ref="jr:itext('/data/ml_ia_k_2501:label')"/>
      <repeat nodeset="/data/ml_ia_k_2501">
        <input ref="/data/ml_ia_k_2501/k_sequential_code">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_sequential_code:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_sequential_code2">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_sequential_code2:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_code_id">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_code_id:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_sch_man_sa">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_sch_man_sa:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_ascaris_lumb_sa">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_ascaris_lumb_sa:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_hookworm_sa">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_hookworm_sa:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_trichuris_sa">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_trichuris_sa:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_sch_hae_sa">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_sch_hae_sa:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_other_parasite">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_other_parasite:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_eggs_other_parasite">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_eggs_other_parasite:label')"/>
        </input>
        <input ref="/data/ml_ia_k_2501/k_remarks">
          <label ref="jr:itext('/data/ml_ia_k_2501/k_remarks:label')"/>
        </input>
      </repeat>
    </group>
  </h:body>
</h:html>
