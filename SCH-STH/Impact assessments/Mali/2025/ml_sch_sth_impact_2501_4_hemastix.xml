<?xml version="1.0" encoding="UTF-8"?>
<h:html xmlns="http://www.w3.org/2002/xforms"
  xmlns:ev="http://www.w3.org/2001/xml-events"
  xmlns:h="http://www.w3.org/1999/xhtml"
  xmlns:jr="http://openrosa.org/javarosa"
  xmlns:odk="http://www.opendatakit.org/xforms"
  xmlns:orx="http://openrosa.org/xforms"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <h:head>
    <h:title>(2025 Jan) - 4. SCH/STH - Urines V2</h:title>
    <model>

      <instance>
        <data id="ml_sch_sth_impact_2501_4_hemastix_v2">
          <u_recorder/>
          <u_district/>
          <u_subdistrict/>
          <u_site/>
          <u_site_id/>
          <C1/>
          <ml_ia_u_2501 jr:template="">
            <C2/>
            <C3/>
            <u_code_id/>
            <u_code_id2/>
            <u_grading/>
            <u_urine_vol/>
            <u_sh_egp_10ml/>
            <u_remarks/>
          </ml_ia_u_2501>
          <u_start/>
          <u_end/>
          <meta>
            <instanceID/>
          </meta>
        </data>
      </instance>

      <itext>
        <translation default="true()" lang="French">
          <text id="/data/ml_ia_u_2501/u_grading/Negatif:label">
            <value>Négatif</value>
          </text>
          <text id="/data/u_site:label">
            <value>Sélectionner le nom du village</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_grading/++:label">
            <value>++</value>
          </text>
          <text id="/data/u_site_id:label">
            <value>Sélectionner le code du village</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_code_id:hint">
            <value>exemple: 12_123_1</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_code_id:jr:constraintMsg">
            <value>Soit, cet identifiant a déjà été utilisé dans ce village, soit le format du code est incorecte. Exemple d'un code 34_567_890</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_sh_egp_10ml:label">
            <value>Nombre d'œufs par 10 ml</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_code_id:label">
            <value>Veuillez enregistrer ce code unique de l'enfant dans les registres et les échantillons de labo</value>
          </text>
          <text id="/data/u_recorder:label">
            <value>Code de l'Opérateur</value>
          </text>
          <text id="/data/u_subdistrict:label">
            <value>Sélectionner l'aire de santé</value>
          </text>
          <text id="/data/ml_ia_u_2501:label">
            <value>Enrôlement</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_code_id2:label">
            <value>Veuillez enregistrer ce code unique de l'enfant dans les registres et les échantillons de labo</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_grading/+++:label">
            <value>+++</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_grading/Trace.hemolysee:label">
            <value>Trace hémolysée</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_urine_vol:label">
            <value>Volume d'urine : Consigner les millilitres (ml) d'urine prélevés sur la personne</value>
          </text>
          <text id="/data/u_district:label">
            <value>Sélectionner le district</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_grading/+:label">
            <value>+</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_code_id2:jr:constraintMsg">
            <value>Le code répéter doit être le même</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_grading/Trace.non.hemolysee:label">
            <value>Trace non hémolysée</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_urine_vol:jr:constraintMsg">
            <value>Le volume doit être limité à 10ml</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_grading:label">
            <value>Graduation de la microhématurie</value>
          </text>
          <text id="/data/ml_ia_u_2501/u_remarks:label">
            <value>Notes additionnelles</value>
          </text>
        </translation>
      </itext>

      <bind nodeset="/data/u_recorder" required="true()" type="int"/>
      <bind db_get="col_1" nodeset="/data/u_district" required="true()" type="string"/>
      <bind db_filter_by_col_1="/data/u_district" db_get="col_2" nodeset="/data/u_subdistrict" required="true()" type="string"/>
      <bind db_filter_by_col_2="/data/u_subdistrict" db_get="col_3" nodeset="/data/u_site" required="true()" type="string"/>
      <bind db_filter_by_col_3="/data/u_site" db_get="col_4" nodeset="/data/u_site_id" required="true()" type="string"/>
      <bind calculate="join(' ',  /data/ml_ia_u_2501/u_code_id )" nodeset="/data/C1" type="text"/>
      <bind calculate="position(..)" nodeset="/data/ml_ia_u_2501/C2" type="text"/>
      <bind calculate="if ( ../C2  = 1,'',substring-after( /data/C1 , ../u_code_id ))" nodeset="/data/ml_ia_u_2501/C3" type="text"/>
      <bind constraint="not(selected( ../C3 ,  ../u_code_id )) and regex(., '^\d{2}_\d{3}_\d{1,3}$')" jr:constraintMsg="jr:itext('/data/ml_ia_u_2501/u_code_id:jr:constraintMsg')" nodeset="/data/ml_ia_u_2501/u_code_id" required="true()" type="string"/>
      <bind constraint=". =  ../u_code_id" jr:constraintMsg="jr:itext('/data/ml_ia_u_2501/u_code_id2:jr:constraintMsg')" nodeset="/data/ml_ia_u_2501/u_code_id2" required="true()" type="string"/>
      <bind nodeset="/data/ml_ia_u_2501/u_grading" required="true()" type="select1"/>
      <bind constraint=". &gt;=0 and .&lt; 11" jr:constraintMsg="jr:itext('/data/ml_ia_u_2501/u_urine_vol:jr:constraintMsg')" nodeset="/data/ml_ia_u_2501/u_urine_vol" required="true()" type="int"/>
      <bind nodeset="/data/ml_ia_u_2501/u_sh_egp_10ml" required="true()" type="int"/>
      <bind nodeset="/data/ml_ia_u_2501/u_remarks" type="text"/>
      <bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/data/u_start" type="dateTime"/>
      <bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/data/u_end" type="dateTime"/>
      <bind jr:preload="uid" nodeset="/data/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body>
    <input ref="/data/u_recorder">
      <label ref="jr:itext('/data/u_recorder:label')"/>
    </input>
    <input ref="/data/u_district">
      <label ref="jr:itext('/data/u_district:label')"/>
    </input>
    <input ref="/data/u_subdistrict">
      <label ref="jr:itext('/data/u_subdistrict:label')"/>
    </input>
    <input ref="/data/u_site">
      <label ref="jr:itext('/data/u_site:label')"/>
    </input>
    <input ref="/data/u_site_id">
      <label ref="jr:itext('/data/u_site_id:label')"/>
    </input>
    <group ref="/data/ml_ia_u_2501">
      <label ref="jr:itext('/data/ml_ia_u_2501:label')"/>
      <repeat nodeset="/data/ml_ia_u_2501">
        <input ref="/data/ml_ia_u_2501/u_code_id">
          <label ref="jr:itext('/data/ml_ia_u_2501/u_code_id:label')"/>
          <hint ref="jr:itext('/data/ml_ia_u_2501/u_code_id:hint')"/>
        </input>
        <input ref="/data/ml_ia_u_2501/u_code_id2">
          <label ref="jr:itext('/data/ml_ia_u_2501/u_code_id2:label')"/>
        </input>
        <select1 ref="/data/ml_ia_u_2501/u_grading">
          <label ref="jr:itext('/data/ml_ia_u_2501/u_grading:label')"/>
          <item>
            <label ref="jr:itext('/data/ml_ia_u_2501/u_grading/Negatif:label')"/>
            <value>Negatif</value>
          </item>
          <item>
            <label ref="jr:itext('/data/ml_ia_u_2501/u_grading/Trace.non.hemolysee:label')"/>
            <value>Trace.non.hemolysee</value>
          </item>
          <item>
            <label ref="jr:itext('/data/ml_ia_u_2501/u_grading/Trace.hemolysee:label')"/>
            <value>Trace.hemolysee</value>
          </item>
          <item>
            <label ref="jr:itext('/data/ml_ia_u_2501/u_grading/+:label')"/>
            <value>+</value>
          </item>
          <item>
            <label ref="jr:itext('/data/ml_ia_u_2501/u_grading/++:label')"/>
            <value>++</value>
          </item>
          <item>
            <label ref="jr:itext('/data/ml_ia_u_2501/u_grading/+++:label')"/>
            <value>+++</value>
          </item>
        </select1>
        <input ref="/data/ml_ia_u_2501/u_urine_vol">
          <label ref="jr:itext('/data/ml_ia_u_2501/u_urine_vol:label')"/>
        </input>
        <input ref="/data/ml_ia_u_2501/u_sh_egp_10ml">
          <label ref="jr:itext('/data/ml_ia_u_2501/u_sh_egp_10ml:label')"/>
        </input>
        <input ref="/data/ml_ia_u_2501/u_remarks">
          <label ref="jr:itext('/data/ml_ia_u_2501/u_remarks:label')"/>
        </input>
      </repeat>
    </group>
  </h:body>
</h:html>
