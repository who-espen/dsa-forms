      <bind calculate="join(' ',  /data/demo_tas_d_9999/d_code_id )" nodeset="/data/C1" type="text"/>
      <bind calculate="position(..)" nodeset="/data/demo_tas_d_9999/C2" type="text"/>
      <bind calculate="if ( ../C2  = 1,'',substring-after( /data/C1 , ../d_code_id ))" nodeset="/data/demo_tas_d_9999/C3" type="text"/>
      <bind nodeset="/data/demo_tas_d_9999/d_id_method" required="true()" type="select1"/>
      <bind jr:constraintMsg="jr:itext('/data/demo_tas_d_9999/d_barcode_id:jr:constraintMsg')" nodeset="/data/demo_tas_d_9999/d_barcode_id" relevant=" ../d_id_method  = 'Scanner'" required="true()" type="barcode"/>
