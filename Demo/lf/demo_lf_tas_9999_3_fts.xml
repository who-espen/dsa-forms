      <bind calculate="if( ../d_id_method  = 'Scanner', concat( ../d_barcode_id ), concat( /data/d_recorder , '_',  /data/d_site_id , '_',  ../d_index_id ))" constraint="not(selected( ../C3 ,  ../d_code_id ))" jr:constraintMsg="jr:itext('/data/demo_tas_d_9999/d_code_id:jr:constraintMsg')" nodeset="/data/demo_tas_d_9999/d_code_id" readonly="true()" required="true()" type="string"/>
