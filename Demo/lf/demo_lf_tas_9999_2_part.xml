            <value>11</value>
          </text>
        </translation>
      </itext>

      <bind nodeset="/data/p_recorder" required="true()" type="select1"/>
      <bind db_get="col_1" nodeset="/data/p_district" required="true()" type="string"/>
      <bind db_filter_by_col_1="/data/p_district" db_get="col_2" nodeset="/data/p_community" required="true()" type="string"/>
      <bind db_filter_by_col_2="/data/p_community" db_get="col_3" nodeset="/data/p_site" required="true()" type="string"/>
      <bind db_filter_by_col_3="/data/p_site" db_get="col_4" nodeset="/data/p_site_id" required="true()" type="string"/>
      <bind calculate="join(' ',  /data/demo_tas_p_9999/p_code_id )" nodeset="/data/C1" type="text"/>
      <bind calculate="position(..)" nodeset="/data/demo_tas_p_9999/C2" type="text"/>
      <bind calculate="if ( ../C2  = 1,'',substring-after( /data/C1 , ../p_code_id ))" nodeset="/data/demo_tas_p_9999/C3" type="text"/>
      <bind nodeset="/data/demo_tas_p_9999/p_consent" required="true()" type="select1"/>
      <bind nodeset="/data/demo_tas_p_9999/p_sex" relevant=" ../p_consent  = 'Yes'" required="true()" type="select1"/>
      <bind nodeset="/data/demo_tas_p_9999/p_age_yrs" relevant=" ../p_consent  = 'Yes'" required="true()" type="int"/>
      <bind constraint=". &lt;=  ../p_age_yrs" jr:constraintMsg="jr:itext('/data/demo_tas_p_9999/p_how_long_lived:jr:constraintMsg')" nodeset="/data/demo_tas_p_9999/p_how_long_lived" relevant=" ../p_consent  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/demo_tas_p_9999/p_id_method" relevant=" ../p_consent  = 'Yes'" required="true()" type="select1"/>
      <bind jr:constraintMsg="jr:itext('/data/demo_tas_p_9999/p_barcode_id:jr:constraintMsg')" nodeset="/data/demo_tas_p_9999/p_barcode_id" relevant=" ../p_id_method  = 'Scanner'" required="true()" type="barcode"/>
      <bind nodeset="/data/demo_tas_p_9999/p_index_id" relevant=" ../p_id_method  = 'Sequential'" required="true()" type="int"/>
      <bind constraint=". =  ../p_index_id" jr:constraintMsg="jr:itext('/data/demo_tas_p_9999/p_index_id2:jr:constraintMsg')" nodeset="/data/demo_tas_p_9999/p_index_id2" relevant=" ../p_id_method  = 'Sequential'" required="true()" type="int"/>
      <bind calculate="if( ../p_id_method  = 'Scanner', concat( ../p_barcode_id ), concat( /data/p_recorder , '_',  /data/p_site_id , '_',  ../p_index_id ))" constraint="not(selected( ../C3 ,  ../p_code_id ))" jr:constraintMsg="jr:itext('/data/demo_tas_p_9999/p_code_id:jr:constraintMsg')" nodeset="/data/demo_tas_p_9999/p_code_id" readonly="true()" relevant=" ../p_consent  = 'Yes'" required="true()" type="string"/>
      <bind nodeset="/data/demo_tas_p_9999/p_ending_survey_note" readonly="true()" relevant=" ../p_consent  = 'No'" type="string"/>
      <bind constraint="regex(., '^.{0,255}$')" jr:constraintMsg="jr:itext('/data/demo_tas_p_9999/p_notes:jr:constraintMsg')" nodeset="/data/demo_tas_p_9999/p_notes" relevant=" ../p_consent  = 'Yes'" type="text"/>
      <bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/data/c_start" type="dateTime"/>
      <bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/data/c_end" type="dateTime"/>
      <bind jr:preload="uid" nodeset="/data/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body>
    <select1 ref="/data/p_recorder">
