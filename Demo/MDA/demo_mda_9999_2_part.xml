<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms"
  xmlns:ev="http://www.w3.org/2001/xml-events"
  xmlns:h="http://www.w3.org/1999/xhtml"
  xmlns:jr="http://openrosa.org/javarosa"
  xmlns:odk="http://www.opendatakit.org/xforms"
  xmlns:orx="http://openrosa.org/xforms"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <h:head>
    <h:title>(Demo) 2. MDA Medicine Receipt Form</h:title>
    <model>

      <instance>
        <data id="ddemo_mda_9999_2_partata">
          <p_state/>
          <p_district/>
          <p_location/>
          <p_location_id/>
          <p_is_oncho/>
          <p_is_lf/>
          <p_is_schisto/>
          <p_is_sth/>
          <p_is_tra/>
          <p_total_pzq/>
          <p_total_alb/>
          <p_total_mbz/>
          <p_total_ivm/>
          <p_total_dec/>
          <p_total_az_sus/>
          <p_total_az_tab/>
          <p_total_tetra/>
          <p_add_note/>
          <p_start/>
          <p_end/>
          <meta>
            <instanceID/>
          </meta>
        </data>
      </instance>

      <itext>
        <translation default="true()" lang="English">
          <text id="/data/p_state:label">
            <value>Select State / Region / Province</value>
          </text>
          <text id="/data/p_is_lf:label">
            <value>Is the district concerned to LF</value>
          </text>
          <text id="/data/p_is_schisto:label">
            <value>Is the district concerned to SCHISTO</value>
          </text>
          <text id="/data/p_total_tetra:label">
            <value>Total Tetracycline received</value>
          </text>
          <text id="/data/p_total_az_tab:label">
            <value>Total Azithromycin tablets received</value>
          </text>
          <text id="/data/p_is_sth/No:label">
            <value>No</value>
          </text>
          <text id="/data/p_total_pzq:label">
            <value>Total Praziquantel received</value>
          </text>
          <text id="/data/p_is_schisto/Yes:label">
            <value>Yes</value>
          </text>
          <text id="/data/p_is_sth:label">
            <value>Is the district concerned to STH</value>
          </text>
          <text id="/data/p_total_mbz:label">
            <value>Total Mebendazole received</value>
          </text>
          <text id="/data/p_total_dec:label">
            <value>Total Diethylcarbamazine received</value>
          </text>
          <text id="/data/p_total_ivm:label">
            <value>Total Ivermectin received</value>
          </text>
          <text id="/data/p_is_sth/Yes:label">
            <value>Yes</value>
          </text>
          <text id="/data/p_location_id:label">
            <value>Enter the ID of village / location / site</value>
          </text>
          <text id="/data/p_is_tra:label">
            <value>Is the district concerned to TRACHOMA</value>
          </text>
          <text id="/data/p_is_lf/Yes:label">
            <value>Yes</value>
          </text>
          <text id="/data/p_is_tra/No:label">
            <value>No</value>
          </text>
          <text id="/data/p_is_oncho:label">
            <value>Is the district concerned to ONCHO</value>
          </text>
          <text id="/data/p_location:label">
            <value>Enter the village / location / site</value>
          </text>
          <text id="/data/p_is_tra/Yes:label">
            <value>Yes</value>
          </text>
          <text id="/data/p_is_schisto/No:label">
            <value>No</value>
          </text>
          <text id="/data/p_district:label">
            <value>Select District / LGA / County</value>
          </text>
          <text id="/data/p_is_oncho/No:label">
            <value>No</value>
          </text>
          <text id="/data/p_total_az_sus:label">
            <value>Total Azithromycin suspension (in l) received</value>
          </text>
          <text id="/data/p_add_note:label">
            <value>Additional Note</value>
          </text>
          <text id="/data/p_is_lf/No:label">
            <value>No</value>
          </text>
          <text id="/data/p_is_oncho/Yes:label">
            <value>Yes</value>
          </text>
          <text id="/data/p_total_alb:label">
            <value>Total Albendazole received</value>
          </text>
        </translation>
      </itext>

      <bind db_get="col_1" nodeset="/data/p_state" required="true()" type="string"/>
      <bind db_filter_by_col_1="/data/p_state" db_get="col_2" nodeset="/data/p_district" required="true()" type="string"/>
      <bind db_filter_by_col_2="/data/p_location" db_get="col_3" nodeset="/data/p_location" required="true()" type="string"/>
      <bind db_filter_by_col_3="/data/p_location" db_get="col_4" nodeset="/data/p_location_id" required="true()" type="string"/>
      <bind nodeset="/data/p_is_oncho" required="true()" type="select1"/>
      <bind nodeset="/data/p_is_lf" required="true()" type="select1"/>
      <bind nodeset="/data/p_is_schisto" required="true()" type="select1"/>
      <bind nodeset="/data/p_is_sth" required="true()" type="select1"/>
      <bind nodeset="/data/p_is_tra" required="true()" type="select1"/>
      <bind nodeset="/data/p_total_pzq" relevant="/data/p_is_schisto  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/p_total_alb" relevant="/data/p_is_oncho  = 'Yes' or  /data/p_is_lf  = 'Yes' or  /data/p_is_sth  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/p_total_mbz" relevant="/data/p_is_sth  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/p_total_ivm" relevant="/data/p_is_oncho  = 'Yes' or  /data/p_is_lf  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/p_total_dec" relevant="/data/p_is_lf  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/p_total_az_sus" relevant="/data/p_is_tra  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/p_total_az_tab" relevant="/data/p_is_tra  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/p_total_tetra" relevant="/data/p_is_tra  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/p_add_note" required="false()" type="string"/>
      <bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/data/p_start" type="dateTime"/>
      <bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/data/p_end" type="dateTime"/>
      <bind jr:preload="uid" nodeset="/data/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body>
    <input ref="/data/p_state">
      <label ref="jr:itext('/data/p_state:label')"/>
    </input>
    <input ref="/data/p_district">
      <label ref="jr:itext('/data/p_district:label')"/>
    </input>
    <input ref="/data/p_location">
      <label ref="jr:itext('/data/p_location:label')"/>
    </input>
    <input ref="/data/p_location_id">
      <label ref="jr:itext('/data/p_location_id:label')"/>
    </input>
    <select1 ref="/data/p_is_oncho">
      <label ref="jr:itext('/data/p_is_oncho:label')"/>
      <item>
        <label ref="jr:itext('/data/p_is_oncho/Yes:label')"/>
        <value>Yes</value>
      </item>
      <item>
        <label ref="jr:itext('/data/p_is_oncho/No:label')"/>
        <value>No</value>
      </item>
    </select1>
    <select1 ref="/data/p_is_lf">
      <label ref="jr:itext('/data/p_is_lf:label')"/>
      <item>
        <label ref="jr:itext('/data/p_is_lf/Yes:label')"/>
        <value>Yes</value>
      </item>
      <item>
        <label ref="jr:itext('/data/p_is_lf/No:label')"/>
        <value>No</value>
      </item>
    </select1>
    <select1 ref="/data/p_is_schisto">
      <label ref="jr:itext('/data/p_is_schisto:label')"/>
      <item>
        <label ref="jr:itext('/data/p_is_schisto/Yes:label')"/>
        <value>Yes</value>
      </item>
      <item>
        <label ref="jr:itext('/data/p_is_schisto/No:label')"/>
        <value>No</value>
      </item>
    </select1>
    <select1 ref="/data/p_is_sth">
      <label ref="jr:itext('/data/p_is_sth:label')"/>
      <item>
        <label ref="jr:itext('/data/p_is_sth/Yes:label')"/>
        <value>Yes</value>
      </item>
      <item>
        <label ref="jr:itext('/data/p_is_sth/No:label')"/>
        <value>No</value>
      </item>
    </select1>
    <select1 ref="/data/p_is_tra">
      <label ref="jr:itext('/data/p_is_tra:label')"/>
      <item>
        <label ref="jr:itext('/data/p_is_tra/Yes:label')"/>
        <value>Yes</value>
      </item>
      <item>
        <label ref="jr:itext('/data/p_is_tra/No:label')"/>
        <value>No</value>
      </item>
    </select1>
    <input ref="/data/p_total_pzq">
      <label ref="jr:itext('/data/p_total_pzq:label')"/>
    </input>
    <input ref="/data/p_total_alb">
      <label ref="jr:itext('/data/p_total_alb:label')"/>
    </input>
    <input ref="/data/p_total_mbz">
      <label ref="jr:itext('/data/p_total_mbz:label')"/>
    </input>
    <input ref="/data/p_total_ivm">
      <label ref="jr:itext('/data/p_total_ivm:label')"/>
    </input>
    <input ref="/data/p_total_dec">
      <label ref="jr:itext('/data/p_total_dec:label')"/>
    </input>
    <input ref="/data/p_total_az_sus">
      <label ref="jr:itext('/data/p_total_az_sus:label')"/>
    </input>
    <input ref="/data/p_total_az_tab">
      <label ref="jr:itext('/data/p_total_az_tab:label')"/>
    </input>
    <input ref="/data/p_total_tetra">
      <label ref="jr:itext('/data/p_total_tetra:label')"/>
    </input>
    <input ref="/data/p_add_note">
      <label ref="jr:itext('/data/p_add_note:label')"/>
    </input>
  </h:body>
</h:html>
