      <instance id="__last-saved" src="jr://instance/last-saved"/>
      <bind nodeset="/data/p_recorder_id" required="true()" type="select1"/>
      <bind db_get="col_1" nodeset="/data/p_admin1" required="true()" type="string"/>
      <bind db_filter_by_col_1=" /data/p_admin1 " db_get="col_2" nodeset="/data/p_district" required="true()" type="string"/>
      <bind db_filter_by_col_2=" /data/p_district " db_get="col_3" nodeset="/data/p_site" required="true()" type="string"/>
      <bind db_filter_by_col_3=" /data/p_site " db_get="col_4" nodeset="/data/p_site_id" required="true()" type="string"/>
      <bind nodeset="/data/p_id_type" required="true()" type="select1"/>
      <bind nodeset="/data/p_warning_note1" relevant=" /data/p_id_type  = 'Auto-generated codes'" required="true()" type="select1"/>
      <bind nodeset="/data/p_warning_note2" relevant=" /data/p_id_type  = 'Scanner' or  /data/p_id_type  = 'Manual numbering'" required="true()" type="select1"/>
      <bind calculate="once(if( instance('__last-saved')/data/p_index_cur !=null, instance('__last-saved')/data/p_index_cur , 0))" db_get="integer" nodeset="/data/p_index_init" type="string"/>
      <bind calculate="join(' ',  /data/o_p_yymm/p_code_id )" nodeset="/data/C1" type="text"/>
      <bind calculate="position(..)" nodeset="/data/o_p_yymm/C2" type="text"/>
      <bind calculate="if ( ../C2  = 1,'',substring-after( /data/C1 , ../p_code_id ))" nodeset="/data/o_p_yymm/C3" type="text"/>
      <bind nodeset="/data/o_p_yymm/p_consent" required="true()" type="select1"/>
      <bind nodeset="/data/o_p_yymm/p_assent" relevant=" ../p_consent  = 'Yes'" required="true()" type="select1"/>
      <bind calculate=" /data/p_index_init  + position(..)" nodeset="/data/o_p_yymm/p_index" readonly="true()" relevant=" ../p_assent  = 'Yes' and  /data/p_id_type  = 'Auto-generated codes'" required="true()" type="int"/>
      <bind calculate="concat( /data/p_site_id , '-',  /data/p_index_init  + position(..))" nodeset="/data/o_p_yymm/p_code_id1" relevant=" ../p_assent  = 'Yes' and  /data/p_id_type  = 'Auto-generated codes'" type="string"/>
      <bind calculate="position(..)" nodeset="/data/o_p_yymm/position" relevant=" ../p_assent  = 'Yes' and  /data/p_id_type  = 'Auto-generated codes'" type="string"/>
      <bind nodeset="/data/o_p_yymm/p_num_order" relevant=" ../p_assent  = 'Yes' and  /data/p_id_type  = 'Manual numbering'" required="true()" type="int"/>
      <bind calculate="concat( /data/p_site_id , '-',  ../p_num_order )" nodeset="/data/o_p_yymm/p_code_id2" relevant=" ../p_assent  = 'Yes' and  /data/p_id_type  = 'Manual numbering'" type="string"/>
      <bind nodeset="/data/o_p_yymm/p_barcode_method" relevant=" ../p_assent  = 'Yes' and  /data/p_id_type  = 'Scanner'" required="true()" type="select1"/>
      <bind nodeset="/data/o_p_yymm/p_code_id3" relevant=" ../p_assent  = 'Yes' and  ../p_barcode_method  = 'QRScann'" required="true()" type="barcode"/>
      <bind nodeset="/data/o_p_yymm/p_code_id4" relevant=" ../p_assent  = 'Yes' and  ../p_barcode_method  = 'QRManual'" required="true()" type="string"/>
      <bind constraint=". =  ../p_code_id4 " jr:constraintMsg="jr:itext('/data/o_p_yymm/p_code_id5:jr:constraintMsg')" nodeset="/data/o_p_yymm/p_code_id5" relevant=" ../p_assent  = 'Yes' and  ../p_barcode_method  = 'QRManual'" required="true()" type="string"/>
      <bind calculate="if( /data/p_id_type  = 'Auto-generated codes',  ../p_code_id1 , if( /data/p_id_type  = 'Manual numbering',  ../p_code_id2 , if( ../p_barcode_method  = 'QRScann',  ../p_code_id3 ,  ../p_code_id5 )))" constraint="not(selected( ../C3 ,  ../p_code_id ))" db_add_col_4=" /data/p_site_id " db_add_col_5="." jr:constraintMsg="jr:itext('/data/o_p_yymm/p_code_id:jr:constraintMsg')" nodeset="/data/o_p_yymm/p_code_id" readonly="true()" relevant=" ../p_assent  = 'Yes'" required="true()" type="string"/>
      <bind nodeset="/data/o_p_yymm/p_sex" relevant=" ../p_assent  = 'Yes'" required="true()" type="select1"/>
      <bind constraint=". &gt;= 5 and . &lt;= 9" jr:constraintMsg="jr:itext('/data/o_p_yymm/p_age_yrs:jr:constraintMsg')" nodeset="/data/o_p_yymm/p_age_yrs" relevant=" ../p_assent  = 'Yes'" required="true()" type="int"/>
      <bind constraint=". &lt;=  ../p_age_yrs " jr:constraintMsg="jr:itext('/data/o_p_yymm/p_how_long_lived:jr:constraintMsg')" nodeset="/data/o_p_yymm/p_how_long_lived" relevant=" ../p_assent  = 'Yes'" required="true()" type="int"/>
      <bind nodeset="/data/o_p_yymm/p_travel" relevant=" ../p_assent  = 'Yes'" required="true()" type="select1"/>
      <bind nodeset="/data/o_p_yymm/p_ever_taken_ivm" relevant=" ../p_assent  = 'Yes'" required="true()" type="select1"/>
      <bind nodeset="/data/o_p_yymm/p_ivm_where" relevant=" ../p_ever_taken_ivm  = 'Yes'" required="true()" type="select1"/>
      <bind nodeset="/data/o_p_yymm/p_ivm" relevant=" ../p_ever_taken_ivm  = 'Yes'"/>
      <bind nodeset="/data/o_p_yymm/p_ivm/last_time_month" required="true()" type="select1"/>
      <bind nodeset="/data/o_p_yymm/p_ivm/last_time_year" required="true()" type="int"/>
      <bind nodeset="/data/o_p_yymm/p_sample_collected" relevant=" ../p_ever_taken_ivm  = 'Yes'" required="true()" type="select1"/>
      <bind nodeset="/data/o_p_yymm/p_end_survey_note" readonly="true()" relevant=" ../p_consent  = 'No' or  ../p_assent  = 'No'" type="string"/>
      <bind nodeset="/data/o_p_yymm/p_additional_notes" type="string"/>
      <bind calculate=" /data/p_index_init  + indexed-repeat( /data/o_p_yymm/position ,  /data/o_p_yymm , count( /data/o_p_yymm ))" nodeset="/data/p_index_cur" relevant=" /data/p_id_type  = 'Auto-generated codes'" type="string"/>
      <bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/data/p_start" type="dateTime"/>
      <bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/data/p_end" type="dateTime"/>
      <bind jr:preload="uid" nodeset="/data/meta/instanceID" readonly="true()" type="string"/>
    </model>
